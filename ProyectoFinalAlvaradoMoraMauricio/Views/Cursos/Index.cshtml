@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<h2>Cursos</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control me-2" placeholder="Buscar por nombre o código" />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </form>

    <a asp-action="Create" class="btn btn-primary">Nuevo curso</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Créditos</th>
            <th>Activo</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var curso in Model)
        {
            <tr>
                <td>@curso.Codigo</td>
                <td>@curso.Nombre</td>
                <td>@curso.Descripcion</td>
                <td>@curso.Creditos</td>
                <td>@(curso.Activo ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@curso.CursoId" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Edit" asp-route-id="@curso.CursoId" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Requisitos" asp-route-id="@curso.CursoId" class="btn btn-secondary btn-sm">Requisitos</a>
                    <a asp-action="Delete" asp-route-id="@curso.CursoId" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>