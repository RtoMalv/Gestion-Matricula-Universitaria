@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Curso>

@{
    ViewData["Title"] = "Cursos";
}

<h1 class="mb-3">Cursos</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Nuevo curso</a>
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Créditos</th>
            <th>Carrera</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Codigo</td>
                <td>@item.Nombre</td>
                <td>@item.Creditos</td>
                <td>@item.Carrera?.Nombre</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.CursoId" class="btn btn-info btn-sm">Ver</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.CursoId" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.CursoId" class="btn btn-danger btn-sm">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
