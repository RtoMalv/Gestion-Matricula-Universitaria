@model ProyectoFinalAlvaradoMoraMauricio.Models.Curso

@{
    ViewData["Title"] = "Detalle de curso";
}

<h2>Detalle de curso</h2>

<dl class="row">
    <dt class="col-sm-3">Código</dt>
    <dd class="col-sm-9">@Model.Codigo</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>

    <dt class="col-sm-3">Descripción</dt>
    <dd class="col-sm-9">@Model.Descripcion</dd>

    <dt class="col-sm-3">Créditos</dt>
    <dd class="col-sm-9">@Model.Creditos</dd>

    <dt class="col-sm-3">Activo</dt>
    <dd class="col-sm-9">@(Model.Activo ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.CursoId" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>