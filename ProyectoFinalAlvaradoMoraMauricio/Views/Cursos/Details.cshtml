@model ProyectoFinalAlvaradoMoraMauricio.Models.Curso

@{
    ViewData["Title"] = "Detalle de curso";
}

<h1>Detalle de curso</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Código</dt>
        <dd class="col-sm-10">@Model.Codigo</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Créditos</dt>
        <dd class="col-sm-10">@Model.Creditos</dd>

        <dt class="col-sm-2">Carrera</dt>
        <dd class="col-sm-10">@Model.Carrera?.Nombre</dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.CursoId" class="btn btn-warning">Editar</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>