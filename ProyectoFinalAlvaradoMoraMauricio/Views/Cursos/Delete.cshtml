@model ProyectoFinalAlvaradoMoraMauricio.Models.Curso

@{
    ViewData["Title"] = "Eliminar curso";
}

<h2>Eliminar curso</h2>

<div class="alert alert-warning">
    ¿Está seguro de que desea eliminar este curso?
</div>

<dl class="row">
    <dt class="col-sm-3">Código</dt>
    <dd class="col-sm-9">@Model.Codigo</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CursoId" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>