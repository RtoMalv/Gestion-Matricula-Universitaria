@model ProyectoFinalAlvaradoMoraMauricio.Models.Matricula

@{
    ViewData["Title"] = "Detalle de matrícula";
}

<h1>Detalle de matrícula</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Estudiante</dt>
        <dd class="col-sm-10">@Model.Estudiante?.Nombre</dd>

        <dt class="col-sm-2">Curso</dt>
        <dd class="col-sm-10">@Model.Curso?.Nombre</dd>

        <dt class="col-sm-2">Fecha</dt>
        <dd class="col-sm-10">@Model.FechaMatricula.ToShortDateString()</dd>

        <dt class="col-sm-2">Estado</dt>
        <dd class="col-sm-10">@Model.Estado</dd>
    </dl>
</div>

<div>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>