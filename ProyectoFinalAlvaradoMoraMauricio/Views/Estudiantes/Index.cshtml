@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Estudiante>

@{
    ViewData["Title"] = "Estudiantes";
}

<h1 class="mb-3">Estudiantes</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Nuevo estudiante</a>
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Teléfono</th>
            <th>Dirección</th>
            <th>Correo</th>
            <th>Carrera</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Telefono</td>
                <td>@item.Direccion</td>
                <td>@item.Correo</td>
                <td>@item.Carrera?.Nombre</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.EstudianteId" class="btn btn-info btn-sm">Ver</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.EstudianteId" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.EstudianteId" class="btn btn-danger btn-sm">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>