@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Estudiante>

@{
    ViewData["Title"] = "Estudiantes";
}

<h2>Estudiantes</h2>

<form asp-action="Index" method="get" class="mb-3 d-flex">
    <input type="text" name="search" value="@ViewData["Search"]" class="form-control me-2" placeholder="Buscar estudiante" />
    <button type="submit" class="btn btn-outline-primary">Buscar</button>
</form>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Carnet</th>
            <th>Nombre</th>
            <th>Correo</th>
            <th>Carrera</th>
            <th>Activo</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var estudiante in Model)
        {
            <tr>
                <td>@estudiante.Carnet</td>
                <td>@estudiante.User.NombreCompleto</td>
                <td>@estudiante.User.Email</td>
                <td>@estudiante.Carrera.Nombre</td>
                <td>@(estudiante.Activo ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@estudiante.EstudianteId" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Edit" asp-route-id="@estudiante.EstudianteId" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@estudiante.EstudianteId" class="btn btn-danger btn-sm">Desactivar</a>
                </td>
            </tr>
        }
    </tbody>
</table>