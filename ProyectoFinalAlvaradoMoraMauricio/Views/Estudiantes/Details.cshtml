@model ProyectoFinalAlvaradoMoraMauricio.Models.Estudiante

@{
    ViewData["Title"] = "Detalle de estudiante";
}

<h2>Detalle de estudiante</h2>

<dl class="row">
    <dt class="col-sm-3">Carnet</dt>
    <dd class="col-sm-9">@Model.Carnet</dd>

    <dt class="col-sm-3">Cédula</dt>
    <dd class="col-sm-9">@Model.User.Cedula</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.User.NombreCompleto</dd>

    <dt class="col-sm-3">Correo</dt>
    <dd class="col-sm-9">@Model.User.Email</dd>

    <dt class="col-sm-3">Teléfono</dt>
    <dd class="col-sm-9">@Model.User.PhoneNumber</dd>

    <dt class="col-sm-3">Dirección</dt>
    <dd class="col-sm-9">@Model.User.Direccion</dd>

    <dt class="col-sm-3">Carrera</dt>
    <dd class="col-sm-9">@Model.Carrera.Nombre</dd>

    <dt class="col-sm-3">Activo</dt>
    <dd class="col-sm-9">@(Model.Activo ? "Sí" : "No")</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.EstudianteId" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>