@model ProyectoFinalAlvaradoMoraMauricio.Models.Estudiante

@{
    ViewData["Title"] = "Desactivar estudiante";
}

<h2>Desactivar estudiante</h2>

<div class="alert alert-warning">
    ¿Está seguro de que desea desactivar este estudiante?
</div>

<dl class="row">
    <dt class="col-sm-3">Carnet</dt>
    <dd class="col-sm-9">@Model.Carnet</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.User.NombreCompleto</dd>

    <dt class="col-sm-3">Correo</dt>
    <dd class="col-sm-9">@Model.User.Email</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="EstudianteId" />
    <button type="submit" class="btn btn-danger">Desactivar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>