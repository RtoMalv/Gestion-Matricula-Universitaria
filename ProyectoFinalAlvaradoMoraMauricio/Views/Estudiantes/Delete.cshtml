@model ProyectoFinalAlvaradoMoraMauricio.Models.Estudiante

@{
    ViewData["Title"] = "Eliminar estudiante";
}

<h1>Eliminar estudiante</h1>

<h3>¿Desea eliminar este estudiante?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Teléfono</dt>
        <dd class="col-sm-10">@Model.Telefono</dd>

        <dt class="col-sm-2">Dirección</dt>
        <dd class="col-sm-10">@Model.Direccion</dd>

        <dt class="col-sm-2">Correo</dt>
        <dd class="col-sm-10">@Model.Correo</dd>

        <dt class="col-sm-2">Carrera</dt>
        <dd class="col-sm-10">@Model.Carrera?.Nombre</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="EstudianteId" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>