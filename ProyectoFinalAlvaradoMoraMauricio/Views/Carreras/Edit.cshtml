@model ProyectoFinalAlvaradoMoraMauricio.Models.Carrera

@{
    ViewData["Title"] = "Editar carrera";
}

<h1>Editar carrera</h1>

<h4>Carrera</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="CarreraId" />

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label"></label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label"></label>
                <textarea asp-for="Descripcion" class="form-control"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="Activa" class="form-check-input" />
                <label asp-for="Activa" class="form-check-label"></label>
            </div>

            <div class="mb-3">
                <button type="submit" class="btn btn-success">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Volver</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
