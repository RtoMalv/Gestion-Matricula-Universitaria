@model ProyectoFinalAlvaradoMoraMauricio.Models.Carrera

@{
    ViewData["Title"] = "Eliminar carrera";
}

<h1>Eliminar carrera</h1>

<h3>¿Desea eliminar esta carrera?</h3>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Model.Descripcion</dd>

        <dt class="col-sm-2">Activa</dt>
        <dd class="col-sm-10">@(Model.Activa ? "Sí" : "No")</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="CarreraId" />
        <button type="submit" class="btn btn-danger">Eliminar</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>