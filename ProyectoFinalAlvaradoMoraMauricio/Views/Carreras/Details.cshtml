@model ProyectoFinalAlvaradoMoraMauricio.Models.Carrera

@{
    ViewData["Title"] = "Detalle de carrera";
}

<h1>Detalle de carrera</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Nombre</dd>

        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Model.Descripcion</dd>

        <dt class="col-sm-2">Activa</dt>
        <dd class="col-sm-10">@(Model.Activa ? "Sí" : "No")</dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.CarreraId" class="btn btn-warning">Editar</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>
