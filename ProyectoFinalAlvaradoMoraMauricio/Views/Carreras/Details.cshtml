@model ProyectoFinalAlvaradoMoraMauricio.Models.Carrera

@{
    ViewData["Title"] = "Detalle de carrera";
}

<h2>Detalle de carrera</h2>

<dl class="row">
    <dt class="col-sm-3">Código</dt>
    <dd class="col-sm-9">@Model.Codigo</dd>

    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.Nombre</dd>

    <dt class="col-sm-3">Descripción</dt>
    <dd class="col-sm-9">@Model.Descripcion</dd>

    <dt class="col-sm-3">Activa</dt>
    <dd class="col-sm-9">@(Model.Activa ? "Sí" : "No")</dd>

    <dt class="col-sm-3">Fecha creación</dt>
    <dd class="col-sm-9">@Model.FechaCreacion</dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.CarreraId" class="btn btn-warning">Editar</a>
<a asp-action="Index" class="btn btn-secondary">Volver</a>