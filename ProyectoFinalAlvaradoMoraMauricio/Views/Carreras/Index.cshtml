@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Carrera>

@{
    ViewData["Title"] = "Carreras";
}

<h1 class="mb-3">Carreras</h1>

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Nueva carrera</a>
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Activa</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Descripcion</td>
                <td>@(item.Activa ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.CarreraId" class="btn btn-info btn-sm">Ver</a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.CarreraId" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.CarreraId" class="btn btn-danger btn-sm">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
