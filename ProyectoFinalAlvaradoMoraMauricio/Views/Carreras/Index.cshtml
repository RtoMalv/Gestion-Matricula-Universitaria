@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.Carrera>

@{
    ViewData["Title"] = "Carreras";
}

<h2>Carreras</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control me-2" placeholder="Buscar por nombre o código" />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </form>

    <a asp-action="Create" class="btn btn-primary">Nueva carrera</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Activa</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var carrera in Model)
        {
            <tr>
                <td>@carrera.Codigo</td>
                <td>@carrera.Nombre</td>
                <td>@carrera.Descripcion</td>
                <td>@(carrera.Activa ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@carrera.CarreraId" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Edit" asp-route-id="@carrera.CarreraId" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Malla" asp-route-id="@carrera.CarreraId" class="btn btn-secondary btn-sm">Malla</a>
                    <a asp-action="Delete" asp-route-id="@carrera.CarreraId" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>