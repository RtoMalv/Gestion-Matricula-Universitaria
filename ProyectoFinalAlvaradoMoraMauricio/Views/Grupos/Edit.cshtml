@model ProyectoFinalAlvaradoMoraMauricio.ViewModels.GrupoViewModel

@{
    ViewData["Title"] = "Editar grupo";
}

<h2>Editar grupo</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="GrupoId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="CursoId" class="form-label"></label>
            <select asp-for="CursoId" class="form-control" asp-items="ViewBag.CursoId">
                <option value="">Seleccione un curso</option>
            </select>
            <span asp-validation-for="CursoId" class="text-danger"></span>
        </div>

        <div class="col-md-6 mb-3">
            <label asp-for="PeriodoAcademicoId" class="form-label"></label>
            <select asp-for="PeriodoAcademicoId" class="form-control" asp-items="ViewBag.PeriodoAcademicoId">
                <option value="">Seleccione un período</option>
            </select>
            <span asp-validation-for="PeriodoAcademicoId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="NumeroGrupo" class="form-label"></label>
            <input asp-for="NumeroGrupo" class="form-control" />
            <span asp-validation-for="NumeroGrupo" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="CupoMaximo" class="form-label"></label>
            <input asp-for="CupoMaximo" class="form-control" />
            <span asp-validation-for="CupoMaximo" class="text-danger"></span>
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="DocentePerfilId" class="form-label"></label>
            <select asp-for="DocentePerfilId" class="form-control" asp-items="ViewBag.DocentePerfilId">
                <option value="">Sin asignar</option>
            </select>
            <span asp-validation-for="DocentePerfilId" class="text-danger"></span>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="Modalidad" class="form-label"></label>
            <select asp-for="Modalidad" class="form-control">
                <option value="Presencial">Presencial</option>
                <option value="Virtual">Virtual</option>
                <option value="Híbrida">Híbrida</option>
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="Estado" class="form-label"></label>
            <select asp-for="Estado" class="form-control">
                <option value="Activo">Activo</option>
                <option value="Cerrado">Cerrado</option>
                <option value="Suspendido">Suspendido</option>
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="Aula" class="form-label"></label>
            <input asp-for="Aula" class="form-control" />
        </div>
    </div>

    <h4>Horario</h4>

    <div class="row">
        <div class="col-md-4 mb-3">
            <label asp-for="DiaSemana" class="form-label"></label>
            <select asp-for="DiaSemana" class="form-control">
                <option>Lunes</option>
                <option>Martes</option>
                <option>Miércoles</option>
                <option>Jueves</option>
                <option>Viernes</option>
                <option>Sábado</option>
            </select>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="HoraInicio" class="form-label"></label>
            <input asp-for="HoraInicio" class="form-control" />
            <span asp-validation-for="HoraInicio" class="text-danger"></span>
        </div>

        <div class="col-md-4 mb-3">
            <label asp-for="HoraFinal" class="form-label"></label>
            <input asp-for="HoraFinal" class="form-control" />
            <span asp-validation-for="HoraFinal" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
