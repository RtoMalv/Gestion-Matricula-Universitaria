@model IEnumerable<ProyectoFinalAlvaradoMoraMauricio.Models.PeriodoAcademico>

@{
    ViewData["Title"] = "Períodos académicos";
}

<h2>Períodos académicos</h2>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form asp-action="Index" method="get" class="d-flex">
        <input type="text" name="search" value="@ViewData["Search"]" class="form-control me-2" placeholder="Buscar período" />
        <button type="submit" class="btn btn-outline-primary">Buscar</button>
    </form>

    <a asp-action="Create" class="btn btn-primary">Nuevo período</a>
</div>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Inicio</th>
            <th>Final</th>
            <th>Activo</th>
            <th style="width:220px;">Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var periodo in Model)
        {
            <tr>
                <td>@periodo.NombrePeriodo</td>
                <td>@periodo.FechaInicio.ToShortDateString()</td>
                <td>@periodo.FechaFinal.ToShortDateString()</td>
                <td>@(periodo.Activo ? "Sí" : "No")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@periodo.PeriodoAcademicoId" class="btn btn-info btn-sm">Detalle</a>
                    <a asp-action="Edit" asp-route-id="@periodo.PeriodoAcademicoId" class="btn btn-warning btn-sm">Editar</a>
                    <a asp-action="Delete" asp-route-id="@periodo.PeriodoAcademicoId" class="btn btn-danger btn-sm">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
