@model ProyectoFinalAlvaradoMoraMauricio.ViewModels.PeriodoAcademicoViewModel

@{
    ViewData["Title"] = "Editar período académico";
}

<h2>Editar período académico</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="PeriodoAcademicoId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="NombrePeriodo" class="form-label"></label>
        <input asp-for="NombrePeriodo" class="form-control" />
        <span asp-validation-for="NombrePeriodo" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label asp-for="FechaInicio" class="form-label"></label>
            <input asp-for="FechaInicio" class="form-control" />
            <span asp-validation-for="FechaInicio" class="text-danger"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="FechaFinal" class="form-label"></label>
            <input asp-for="FechaFinal" class="form-control" />
            <span asp-validation-for="FechaFinal" class="text-danger"></span>
        </div>
    </div>

    <div class="form-check mb-3">
        <input asp-for="Activo" class="form-check-input" />
        <label asp-for="Activo" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Guardar cambios</button>
    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
