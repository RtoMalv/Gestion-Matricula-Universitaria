@model ProyectoFinalAlvaradoMoraMauricio.Models.DocentePerfil

@{
    ViewData["Title"] = "Eliminar docente";
}

<h2>Eliminar docente</h2>

<div class="alert alert-warning">
    ¿Está seguro de que desea eliminar este docente?
</div>

<dl class="row">
    <dt class="col-sm-3">Nombre</dt>
    <dd class="col-sm-9">@Model.User.NombreCompleto</dd>

    <dt class="col-sm-3">Correo</dt>
    <dd class="col-sm-9">@Model.User.Email</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="DocentePerfilId" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>